<Window x:Class="EmployeeSearch.Views.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Employee Search"
        Height="700" Width="1000"
        MinHeight="560" MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Label style -->
        <Style x:Key="FilterLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <!-- TextBox style -->
        <Style x:Key="FilterInput" TargetType="TextBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="9,0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- ComboBox style -->
        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="Height" Value="36"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="7,0"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="Background" Value="White"/>
        </Style>

        <!-- Primary button style -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1B4F8A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#154080"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#0F3060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button style -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Padding" Value="18,0"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid cell style -->
        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#1E3A5F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Background="#F3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>   <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Filter panel -->
            <RowDefinition Height="*"/>    <!-- Results -->
            <RowDefinition Height="34"/>   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <Border Grid.Row="0" Background="#1B2A4A">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.3" Color="#000000"/>
            </Border.Effect>
            <Grid Margin="20,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔍" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="Employee Search" FontSize="20" FontWeight="Bold"
                               Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="UserLabel" FontSize="13" Foreground="#93C5FD"
                               VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <Button Content="Logout" Style="{StaticResource SecondaryButton}"
                            Height="30" Padding="14,0" Click="LogoutButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Filter Panel ═══ -->
        <Border Grid.Row="1" Background="White" Margin="16,14,16,0"
                CornerRadius="8" Padding="20,16">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08" Color="#000000"/>
            </Border.Effect>

            <StackPanel>
                <TextBlock Text="Search Filters" FontSize="14" FontWeight="Bold"
                           Foreground="#1F2937" Margin="0,0,0,14"/>

                <!-- Row 1: Name + Department + Role -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="160"/>
                    </Grid.ColumnDefinitions>

                    <!-- Name -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Employee Name" Style="{StaticResource FilterLabel}"/>
                        <TextBox x:Name="NameBox" Style="{StaticResource FilterInput}"
                                 KeyDown="Filter_KeyDown"/>
                    </StackPanel>

                    <!-- Department -->
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Department" Style="{StaticResource FilterLabel}"/>
                        <ComboBox x:Name="DepartmentCombo" Style="{StaticResource FilterCombo}">
                            <ComboBoxItem Content="All" IsSelected="True"/>
                            <ComboBoxItem Content="Finance"/>
                            <ComboBoxItem Content="HR"/>
                            <ComboBoxItem Content="IT"/>
                            <ComboBoxItem Content="Marketing"/>
                            <ComboBoxItem Content="Operations"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Role -->
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Role" Style="{StaticResource FilterLabel}"/>
                        <ComboBox x:Name="RoleCombo" Style="{StaticResource FilterCombo}">
                            <ComboBoxItem Content="All" IsSelected="True"/>
                            <ComboBoxItem Content="Analyst"/>
                            <ComboBoxItem Content="Coordinator"/>
                            <ComboBoxItem Content="Designer"/>
                            <ComboBoxItem Content="Developer"/>
                            <ComboBoxItem Content="Manager"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>

                <!-- Row 2: Status + Buttons -->
                <Grid Margin="0,12,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Status -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Status" Style="{StaticResource FilterLabel}"/>
                        <ComboBox x:Name="StatusCombo" Style="{StaticResource FilterCombo}">
                            <ComboBoxItem Content="All" IsSelected="True"/>
                            <ComboBoxItem Content="Active"/>
                            <ComboBoxItem Content="Inactive"/>
                            <ComboBoxItem Content="On Leave"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Buttons aligned to bottom right -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Bottom">
                        <Button Content="🔍  Search" Style="{StaticResource PrimaryButton}"
                                Click="SearchButton_Click" Margin="0,0,10,0"/>
                        <Button Content="Clear" Style="{StaticResource SecondaryButton}"
                                Click="ClearButton_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ═══ Results Grid ═══ -->
        <Border Grid.Row="2" Background="White" Margin="16,12,16,0"
                CornerRadius="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="6" ShadowDepth="1" Opacity="0.08" Color="#000000"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Results" FontSize="14" FontWeight="Bold"
                           Foreground="#1F2937" Margin="16,14,0,10"/>

                <DataGrid x:Name="ResultsGrid" Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F3F4F6"
                          RowBackground="White"
                          AlternatingRowBackground="#FAFAFA"
                          ColumnHeaderHeight="38"
                          RowHeight="38"
                          BorderThickness="0"
                          Margin="0,0,0,0">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="#F9FAFB"/>
                            <Setter Property="Foreground" Value="#6B7280"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Padding" Value="8,0"/>
                            <Setter Property="BorderBrush" Value="#E5E7EB"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="#"           Binding="{Binding Id}"         Width="50"/>
                        <DataGridTextColumn Header="Name"        Binding="{Binding Name}"        Width="*" MinWidth="120"/>
                        <DataGridTextColumn Header="Department"  Binding="{Binding Department}"  Width="110"/>
                        <DataGridTextColumn Header="Role"        Binding="{Binding Role}"        Width="110"/>
                        <DataGridTemplateColumn Header="Status"  Width="90">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="10" Padding="8,3"
                                            HorizontalAlignment="Left" Margin="4,0">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#E5E7EB"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="Active">
                                                        <Setter Property="Background" Value="#D1FAE5"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="Inactive">
                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="On Leave">
                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock FontSize="11" FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding Status}"/>
                                                    <Setter Property="Foreground" Value="#374151"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Active">
                                                            <Setter Property="Foreground" Value="#065F46"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Inactive">
                                                            <Setter Property="Foreground" Value="#991B1B"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="On Leave">
                                                            <Setter Property="Foreground" Value="#92400E"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Email"       Binding="{Binding Email}"       Width="*" MinWidth="140"/>
                        <DataGridTextColumn Header="Phone"       Binding="{Binding Phone}"       Width="100"/>
                        <DataGridTextColumn Header="Hire Date"   Binding="{Binding HireDate}"    Width="95"/>
                        <DataGridTextColumn Header="Salary"      Binding="{Binding SalaryFormatted}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyState" Grid.Row="1"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="Collapsed">
                    <TextBlock Text="No results found" FontSize="16" FontWeight="SemiBold"
                               Foreground="#6B7280" HorizontalAlignment="Center"/>
                    <TextBlock Text="Try adjusting your search filters" FontSize="13"
                               Foreground="#9CA3AF" HorizontalAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Status Bar ═══ -->
        <Border Grid.Row="3" Background="#E5E7EB" Margin="16,6,16,8" CornerRadius="5"
                Padding="12,0">
            <TextBlock x:Name="StatusText" FontSize="12" Foreground="#6B7280"
                       VerticalAlignment="Center" Text="Use filters above and click Search to find employees."/>
        </Border>
    </Grid>
</Window>
